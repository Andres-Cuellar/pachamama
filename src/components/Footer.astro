---
const year = new Date().getFullYear();
import logo from '../assets/logo.webp'
---

<footer id="site-footer">
  <div class="footer-inner">

    <!-- Brand col -->
    <div class="footer-col footer-col--brand">
      <a href="/" class="footer-logo">
        <img src={logo.src} alt="Pachamama" />
      </a>
      <p class="footer-tagline">
        Diseño y respaldo que acompañan tu vida.
      </p>
      <p class="footer-cities">Bogotá · Medellín · Cobertura nacional</p>
      <!-- Social icons -->
      <div class="footer-social">
        <a href="https://www.facebook.com/pachamama" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
          <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073c0 6.027 4.388 11.023 10.125 11.927v-8.437H7.078v-3.49h3.047V9.413c0-3.025 1.791-4.697 4.533-4.697 1.313 0 2.686.235 2.686.235v2.97h-1.513c-1.491 0-1.956.93-1.956 1.886v2.266h3.328l-.532 3.49h-2.796v8.437C19.612 23.096 24 18.1 24 12.073Z"/>
          </svg>
        </a>
        <a href="https://www.instagram.com/pachamama" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069Zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0Zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324ZM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8Zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881Z"/>
          </svg>
        </a>
        <a href="https://www.tiktok.com/@pachamama" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
          <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.19 8.19 0 0 0 4.79 1.52V6.76a4.86 4.86 0 0 1-1.02-.07Z"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Servicios col -->
    <div class="footer-col">
      <h4 class="footer-col__title">Servicios</h4>
      <ul class="footer-nav">
        <li><a href="/clean">Pachamama Clean</a></li>
        <li><a href="/pachamama-home">Pachamama HomeCare</a></li>
        <li><a href="/click-and-go">Click &amp; Go</a></li>
        <li><a href="/experiencia">Experiencia Click &amp; Go</a></li>
      </ul>
    </div>

    <!-- Beneficios col -->
    <div class="footer-col">
      <h4 class="footer-col__title">Beneficios</h4>
      <ul class="footer-nav">
        <li><a href="/pachamama-club">Pachamama Club</a></li>
        <li><a href="/garantia-viva">Pachamama Viva</a></li>
      </ul>
      <h4 class="footer-col__title" style="margin-top: 1.75rem;">Nosotros</h4>
      <ul class="footer-nav">
        <li><a href="/nosotros">Quiénes somos</a></li>
        <li><a href="/faq">Preguntas frecuentes</a></li>
        <li><a href="/contacto">Contacto y puntos de atención</a></li>
      </ul>
    </div>

    <!-- Legal col -->
    <div class="footer-col">
      <h4 class="footer-col__title">Legal</h4>
      <ul class="footer-nav">
        <li><a href="#">Política de garantías</a></li>
        <li><a href="#">Política de pagos</a></li>
        <li><a href="#">Términos y condiciones</a></li>
        <li><a href="#">Política de privacidad</a></li>
      </ul>
    </div>

  </div>

  <div class="footer-bottom">
    <span class="footer-copy">© {year} Pachamama. Todos los derechos reservados.</span>
  </div>
</footer>
