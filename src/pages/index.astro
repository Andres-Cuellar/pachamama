				</div>
				<div class="service-card fade-in fade-in-delay-1">
					<div class="img-placeholder" data-label="Colechos"></div>
					<div class="service-card__body">
						<h3 class="service-card__title">Colechos</h3>
					</div>
				</div>
				<div class="service-card fade-in fade-in-delay-2">
					<div class="img-placeholder" data-label="Portabebés"></div>
					<div class="service-card__body">
						<h3 class="service-card__title">Portabebés</h3>
					</div>
				</div>
				<div class="service-card fade-in fade-in-delay-3">
					<div class="img-placeholder" data-label="Mecedoras"></div>
					<div class="service-card__body">
						<h3 class="service-card__title">Mecedoras</h3>
					</div>
				</div>
				<div class="service-card fade-in fade-in-delay-4">
					<div
						class="img-placeholder"
