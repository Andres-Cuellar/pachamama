---
import Welcome from "../components/Welcome.astro";
import Layout from "../layouts/Layout.astro";
import antes from "../assets/image/hero/antes.webp";
import despues from "../assets/image/hero/despues.webp";
import desinfeccion from "../assets/image/slide-hero/desinfeccion.webp";
import equipo from "../assets/image/slide-hero/equipo.webp";
import lavanderia from "../assets/image/slide-hero/lavanderia.webp";
import limpieza from "../assets/image/slide-hero/limpieza.webp";
import vapor from "../assets/image/slide-hero/vapor.webp";
import coche from "../assets/image/covertura/coche.webp";
import sillaCarro from "../assets/image/covertura/silla_carro.webp";
import sillaHuevito from "../assets/image/covertura/silla_huevito.webp";
import corral from "../assets/image/covertura/corral.webp";
import colecho from "../assets/image/covertura/colecho.webp";
import cocheSilla from "../assets/image/covertura/coche_silla.webp";
import mecedoras from "../assets/image/covertura/Mecedoras.webp";
import carrycot from "../assets/image/covertura/carrycot.webp";
import procesoDesarmado from "../assets/image/proceso/desarmado.webp";
import procesoLavado from "../assets/image/proceso/lavado.webp";
import procesoRuedas from "../assets/image/proceso/ruedas.webp";
import procesoUv from "../assets/image/proceso/uv.webp";
import momento from "../assets/image/momento/momento.webp";
import reutilizacionAntes from "../assets/image/reutilizacion/antes.webp";
import reutilizacionDespues from "../assets/image/reutilizacion/despues.webp";
import casoViaje from "../assets/image/casos/viaje.webp";
import casoPiso from "../assets/image/casos/piso.webp";
import casoBodega from "../assets/image/casos/bodega.webp";
import click1 from "../assets/image/click-and-go/1.webp";
import click2 from "../assets/image/click-and-go/2.webp";
import click3 from "../assets/image/click-and-go/3.webp";
import click4 from "../assets/image/click-and-go/4.webp";
import click5 from "../assets/image/click-and-go/5.webp";
import click6 from "../assets/image/click-and-go/6.webp";
import experienciaCag from "../assets/image/experiencia-c-a-g.webp";
import pachamamaViva from "../assets/image/pachamama-viva.webp";

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout>
	<!-- ─── 1. HERO ──────────────────────────────────────────── -->
	<section class="hero section--alt">
		<div class="container">
			<div class="split hero__split">
				<div class="split__text">
					<span class="eyebrow fade-in"
						>Pachamama Clean · Bogotá y Medellín</span
					>
					<h1 class="hero__headline fade-in fade-in-delay-1">
						<span class="h1-span"
							>Tu bebé pasa horas en su coche.</span
						><br />
						¿Estás seguro de que está realmente limpio?
					</h1>
					<p class="hero__sub fade-in fade-in-delay-2">
						Spa especializado en limpieza profunda, desinfección
						UV‑C y mantenimiento técnico para coches de bebé, sillas
						de carro, corrales y artículos infantiles en Bogotá y
						Medellín.
					</p>
					<p class="fade-in fade-in-delay-2">
						En Pachamama Clean cuidamos los artículos que acompañan
						la vida diaria de las familias. Nuestro proceso combina
						desarme técnico, lavado profundo, desinfección en cabina
						UV-C y mantenimiento especializado, devolviendo a los
						artículos mejor apariencia, mejor funcionamiento y más
						vida útil.
					</p>
					<div class="tag-row fade-in fade-in-delay-3">
						<span class="mini-badge"
							>25.000+ artículos procesados</span
						>
						<span class="mini-badge"
							>13.000+ familias atendidas</span
						>
						<span class="mini-badge">8 años de experiencia</span>
					</div>
					<div class="note-box fade-in fade-in-delay-3">
						<p>
							<strong
								>¿No sabes qué servicio necesita tu artículo?</strong
							><br />Envíanos una foto por WhatsApp y te
							orientamos en minutos.
						</p>
					</div>
					<div class="btn-group mt-lg fade-in fade-in-delay-4">
						<a
							href="https://wa.me/?text=Hola%20Pachamama%2C%20quiero%20enviar%20una%20foto%20de%20mi%20art%C3%ADculo%20para%20orientaci%C3%B3n."
							class="whatsapp-btn">Enviar foto por WhatsApp</a
						>
						<a href="#proceso-clean" class="btn btn-outline"
							>Ver cómo funciona</a
						>
					</div>
				</div>
				<div class="fade-in fade-in-delay-2">
					<div
						class="compare"
						aria-label="Comparacion antes y despues"
					>
						<img
							class="compare__img compare__img--before"
							src={antes.src}
							alt="Antes de la limpieza"
						/>
						<div class="compare__after">
							<img
								class="compare__img"
								src={despues.src}
								alt="Despues de la limpieza"
							/>
						</div>
						<div class="compare__handle" aria-hidden="true">
							<span class="compare__arrow"></span>
						</div>
						<input
							class="compare__range"
							type="range"
							min="0"
							max="100"
							value="50"
							aria-label="Desliza para comparar antes y despues"
							oninput="this.parentElement.style.setProperty('--pos', this.value + '%')"
						/>
						<div class="compare__label compare__label--before">Antes</div>
						<div class="compare__label compare__label--after">Despues</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ─── 2. AUTORIDAD Y SEGURIDAD ─────────────────────────── -->
	<section class="section" style="border-top: 1px solid var(--gray-200);">
		<div class="container">
			<div class="split">
				<div class="split__text">
					<span class="eyebrow fade-in">Autoridad técnica</span>
					<h2 class="fade-in fade-in-delay-1">
						El cuidado de artículos de bebé también es un tema de
						seguridad
					</h2>
					<div class="divider fade-in fade-in-delay-2"></div>
					<p class="fade-in fade-in-delay-2">
						Muchos artículos infantiles pueden lavarse en casa, pero
						productos como coches de bebé o sillas de auto están
						diseñados con estructuras y mecanismos que requieren un
						armado correcto para garantizar su funcionamiento y
						seguridad.
					</p>
					<p class="mt-md fade-in fade-in-delay-3">
						En Pachamama, los artículos son intervenidos y
						ensamblados por técnicos especializados en productos
						infantiles, lo que permite asegurar que el artículo
						quede correctamente armado y funcionando según las
						condiciones para las que fue diseñado por el fabricante.
					</p>
				</div>
				<div class="fade-in fade-in-delay-2">
					<div class="hero-slider hero-slider--manual" aria-label="Slide de procesos">
						<div class="hero-slider__slide is-active" style="animation-delay: 0s;">
							<img src={equipo.src} alt="Equipo tecnico" loading="lazy" />
						</div>
						<div class="hero-slider__slide" style="animation-delay: 4s;">
							<img src={limpieza.src} alt="Limpieza profunda" loading="lazy" />
						</div>
						<div class="hero-slider__slide" style="animation-delay: 8s;">
							<img src={lavanderia.src} alt="Lavanderia tecnica" loading="lazy" />
						</div>
						<div class="hero-slider__slide" style="animation-delay: 12s;">
							<img src={desinfeccion.src} alt="Desinfeccion" loading="lazy" />
						</div>
						<div class="hero-slider__slide" style="animation-delay: 16s;">
							<img src={vapor.src} alt="Limpieza con vapor" loading="lazy" />
						</div>
						<div class="hero-slider__badge">Proceso real</div>
						<div class="hero-slider__nav" aria-hidden="false">
							<button class="hero-slider__btn hero-slider__btn--prev" type="button" aria-label="Imagen anterior">
								<span aria-hidden="true">‹</span>
							</button>
							<button class="hero-slider__btn hero-slider__btn--next" type="button" aria-label="Imagen siguiente">
								<span aria-hidden="true">›</span>
							</button>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ─── 3. PRUEBA SOCIAL / CIFRAS ────────────────────────── -->
	<section class="section section--alt">
		<div class="container">
			<div class="text-center mb-md">
				<span class="eyebrow fade-in">Resultados</span>
				<h2 class="fade-in fade-in-delay-1">
					Más de 25.000 artículos de bebé restaurados en Bogotá y
					Medellín
				</h2>
				<div class="divider divider--center fade-in fade-in-delay-2">
				</div>
				<p
					class="lead mt-md fade-in fade-in-delay-2"
					style="max-width: 860px; margin-left: auto; margin-right: auto;"
				>
					Durante ocho años hemos desarrollado un proceso técnico
					especializado para limpiar, desinfectar y mantener artículos
					infantiles que muchas familias no saben cómo tratar
					correctamente en casa.
				</p>
			</div>
			<div class="grid-4 mt-xl">
				<div class="card--price fade-in fade-in-delay-1">
					<div class="price-label">Indicador</div>
					<div class="price-amount" data-target="25000" data-suffix="+">0</div>
					<div class="price-name">Artículos procesados</div>
				</div>
				<div class="card--price fade-in fade-in-delay-2">
					<div class="price-label">Indicador</div>
					<div class="price-amount" data-target="13000" data-suffix="+">0</div>
					<div class="price-name">Familias atendidas</div>
				</div>
				<div class="card--price fade-in fade-in-delay-3">
					<div class="price-label">Indicador</div>
					<div class="price-amount" data-target="8">0</div>
					<div class="price-name">Años de operación</div>
				</div>
				<div class="card--price fade-in fade-in-delay-4">
					<div class="price-label">Cobertura</div>
					<div class="price-amount" style="font-size: 1.6rem;">Bogotá y Medellín</div>
					<div class="price-name">Ciudades principales</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ─── 4. ARTÍCULOS QUE TRATAMOS ────────────────────────── -->
	<section class="section">
		<div class="container">
			<span class="eyebrow fade-in">Cobertura de servicio</span>
			<h2 class="fade-in fade-in-delay-1">
				Artículos que tratamos en Pachamama Clean
			</h2>
			<div class="divider fade-in fade-in-delay-2"></div>
			<div class="grid-4 mt-lg">
				<div class="service-card fade-in fade-in-delay-1">
					<div class="service-card__media">
						<img src={coche.src} alt="Coches de bebe" loading="lazy" />
					</div>
					<div class="service-card__body">
						<h3 class="service-card__title">Coches de bebé</h3>
					</div>
				</div>
				<div class="service-card fade-in fade-in-delay-2">
					<div class="service-card__media">
						<img src={sillaCarro.src} alt="Sillas de carro" loading="lazy" />
					</div>
					<div class="service-card__body">
						<h3 class="service-card__title">
							Sillas de carro
						</h3>
					</div>
				</div>
				<div class="service-card fade-in fade-in-delay-3">
					<div class="service-card__media">
						<img src={sillaHuevito.src} alt="Sillas huevito" loading="lazy" />
					</div>
					<div class="service-card__body">
						<h3 class="service-card__title">Sillas huevito</h3>
					</div>
				</div>
				<div class="service-card fade-in fade-in-delay-4">
					<div class="service-card__media">
						<img src={corral.src} alt="Corrales" loading="lazy" />
					</div>
					<div class="service-card__body">
						<h3 class="service-card__title">Corrales</h3>
					</div>
				</div>
				<div class="service-card fade-in fade-in-delay-1">
					<div class="service-card__media">
						<img src={colecho.src} alt="Colechos" loading="lazy" />
					</div>
					<div class="service-card__body">
						<h3 class="service-card__title">Colechos</h3>
					</div>
				</div>
				<div class="service-card fade-in fade-in-delay-2">
					<div class="service-card__media">
						<img src={cocheSilla.src} alt="Coche y silla" loading="lazy" />
					</div>
					<div class="service-card__body">
						<h3 class="service-card__title">Coche + Silla</h3>
					</div>
				</div>
				<div class="service-card fade-in fade-in-delay-3">
					<div class="service-card__media">
						<img src={mecedoras.src} alt="Mecedoras" loading="lazy" />
					</div>
					<div class="service-card__body">
						<h3 class="service-card__title">Mecedoras</h3>
					</div>
				</div>
				<div class="service-card fade-in fade-in-delay-4">
					<div class="service-card__media">
						<img src={carrycot.src} alt="Textiles infantiles" loading="lazy" />
					</div>
					<div class="service-card__body">
						<h3 class="service-card__title">Carrycot / Bassinet</h3>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ─── 5. PROCESO ───────────────────────────────────────── -->
	<section id="proceso-clean" class="section section--alt">
		<div class="container">
			<div class="text-center mb-md">
				<span class="eyebrow fade-in">Proceso técnico</span>
				<h2 class="fade-in fade-in-delay-1">Mucho más que un lavado</h2>
				<div class="divider divider--center fade-in fade-in-delay-2">
				</div>
				<p class="lead mt-md fade-in fade-in-delay-2">
					Cada artículo pasa por un proceso técnico de limpieza
					profunda, desinfección y mantenimiento especializado.
				</p>
			</div>
			<div class="steps mt-lg fade-in fade-in-delay-2">
				<div class="step">
					<div class="step__num">1</div>
					<div class="step__content">
						<h4>Inspección inicial</h4>
						<p>
							Evaluamos estado general, textiles, ruedas,
							rodamientos y mecanismos.
						</p>
					</div>
				</div>
				<div class="step">
					<div class="step__num">2</div>
					<div class="step__content">
						<h4>Desarme técnico</h4>
						<p>
							Se desmontan piezas para acceder a zonas difíciles.
						</p>
					</div>
				</div>
				<div class="step">
					<div class="step__num">3</div>
					<div class="step__content">
						<h4>Lavado profundo</h4>
						<p>
							Se limpian textiles, chasis, ruedas y piezas
							plásticas.
						</p>
					</div>
				</div>
				<div class="step">
					<div class="step__num">4</div>
					<div class="step__content">
						<h4>Mantenimiento de ruedas y rodamientos</h4>
						<p>
							Se retiran residuos como pelo, polvo y fibras
							acumuladas. Posteriormente se lubrican los
							rodamientos con aceite siliconado para mejorar su
							funcionamiento.
						</p>
					</div>
				</div>
				<div class="step">
					<div class="step__num">5</div>
					<div class="step__content">
						<h4>Revisión de mecanismos</h4>
						<p>
							Se revisan frenos, sistemas de plegado y uniones
							móviles.
						</p>
					</div>
				</div>
				<div class="step">
					<div class="step__num">6</div>
					<div class="step__content">
						<h4>Desinfección en cabina UV‑C</h4>
						<p>
							Los artículos pasan por una cabina de luz
							ultravioleta que ayuda a reducir microorganismos
							presentes en superficies textiles y plásticas.
						</p>
					</div>
				</div>
				<div class="step">
					<div class="step__num">7</div>
					<div class="step__content">
						<h4>Reensamble técnico y control final</h4>
						<p>
							El artículo se arma nuevamente y se realiza una
							revisión final de funcionamiento.
						</p>
					</div>
				</div>
			</div>
			<div class="grid-4 mt-xl">
				<div class="process-media fade-in">
					<img src={procesoDesarmado.src} alt="Desarme tecnico" loading="lazy" />
				</div>
				<div
					class="process-media fade-in fade-in-delay-1"
				>
					<img src={procesoLavado.src} alt="Lavado profundo" loading="lazy" />
				</div>
				<div
					class="process-media fade-in fade-in-delay-2"
				>
					<img src={procesoRuedas.src} alt="Ruedas y rodamientos" loading="lazy" />
				</div>
				<div
					class="process-media fade-in fade-in-delay-3"
				>
					<img src={procesoUv.src} alt="Cabina UV-C" loading="lazy" />
				</div>
			</div>
		</div>
	</section>

	<!-- ─── 5b. SEÑALES ──────────────────────────────────────── -->
	<section class="section">
		<div class="container">
			<div class="split">
				<div class="split__text">
					<span class="eyebrow fade-in">¿Es tu momento?</span>
					<h2 class="fade-in fade-in-delay-1">
						¿Tu coche de bebé necesita limpieza o mantenimiento?
					</h2>
					<div class="divider fade-in fade-in-delay-2"></div>
					<p class="fade-in fade-in-delay-2">
						Muchas familias nos escriben cuando comienzan a notar
						ciertas señales en sus coches de bebé o artículos
						infantiles.
					</p>
					<ul class="check-list mt-md fade-in fade-in-delay-3">
						<li>Las ruedas ya no giran suavemente</li>
						<li>El coche hace ruido al empujarlo</li>
						<li>Las telas tienen manchas difíciles</li>
						<li>El coche estuvo guardado durante meses o años</li>
						<li>Quieres reutilizarlo para un segundo bebé</li>
						<li>El coche se ensució en un viaje o aeropuerto</li>
						<li>El coche ya no se siente limpio o higiénico</li>
					</ul>
					<div class="note-box mt-md fade-in fade-in-delay-4">
						<p>
							Envíanos una foto por WhatsApp y te orientamos en
							minutos.
						</p>
					</div>
				</div>
				<div class="fade-in fade-in-delay-2">
					<div class="service-card__media" style="aspect-ratio: 4/5;">
						<img
							src={momento.src}
							alt="Ruedas desgastadas y telas manchadas"
							loading="lazy"
						/>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ─── 6. SEGUNDA VIDA ──────────────────────────────────── -->
	<section class="section">
		<div class="container">
			<div class="split split--reverse">
				<div class="split__text">
					<span class="eyebrow fade-in">Reutilización consciente</span
					>
					<h2 class="fade-in fade-in-delay-1">
						Darle una segunda oportunidad a los artículos de bebé
					</h2>
					<div class="divider fade-in fade-in-delay-2"></div>
					<p class="fade-in fade-in-delay-2">
						Muchas familias guardan coches de bebé o sillas después
						del primer hijo.
					</p>
					<p class="mt-md fade-in fade-in-delay-3">
						Nuestro servicio permite recuperarlos para que puedan
						volver a utilizarse con un segundo bebé o incluso ser
						regalados a otra familia.
					</p>
					<p class="mt-md fade-in fade-in-delay-3">
						Además de ahorrar dinero, esta práctica ayuda a extender
						la vida útil de los productos y reducir el impacto
						ambiental que generan los artículos infantiles cuando se
						desechan prematuramente.
					</p>
				</div>
				<div class="fade-in fade-in-delay-2">
					<div
						class="compare"
						style="aspect-ratio: 4/5;"
						aria-label="Comparacion antes y despues del coche restaurado"
					>
						<img
							class="compare__img compare__img--before"
							src={reutilizacionAntes.src}
							alt="Antes de la restauracion"
						/>
						<div class="compare__after">
							<img
								class="compare__img"
								src={reutilizacionDespues.src}
								alt="Despues de la restauracion"
							/>
						</div>
						<div class="compare__handle" aria-hidden="true">
							<span class="compare__arrow"></span>
						</div>
						<input
							class="compare__range"
							type="range"
							min="0"
							max="100"
							value="50"
							aria-label="Desliza para comparar antes y despues"
							oninput="this.parentElement.style.setProperty('--pos', this.value + '%')"
						/>
						<div class="compare__label compare__label--before">Antes</div>
						<div class="compare__label compare__label--after">Despues</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ─── 7. CASOS DE CONTACTO ─────────────────────────────── -->
	<section class="section section--alt">
		<div class="container">
			<span class="eyebrow fade-in">Casos frecuentes</span>
			<h2 class="fade-in fade-in-delay-1">
				Situaciones en las que muchas familias nos buscan
			</h2>
			<div class="divider fade-in fade-in-delay-2"></div>
			<div class="grid-3 mt-lg">
				<div class="card fade-in fade-in-delay-1">
					<h3 class="service-card__title">Uso diario del coche</h3>
				</div>
				<div class="card fade-in fade-in-delay-2">
					<h3 class="service-card__title">
						Viajes frecuentes con el bebé
					</h3>
				</div>
				<div class="card fade-in fade-in-delay-3">
					<h3 class="service-card__title">
						Salidas al parque o a la finca
					</h3>
				</div>
				<div class="card fade-in fade-in-delay-1">
