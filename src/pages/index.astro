	<!-- ─── 6. SEGUNDA VIDA ──────────────────────────────────── -->
	<section class="section">
		<div class="container">
			<div class="split split--reverse">
				<div class="split__text">
					<span class="eyebrow fade-in">Reutilización consciente</span
