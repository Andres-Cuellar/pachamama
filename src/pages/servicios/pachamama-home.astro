---
import Layout from "../../layouts/Layout.astro";
---

<Layout>
  <!-- ─── HERO ─────────────────────────────────────────────── -->
  <section class="hero hero--compact section--alt">
    <div class="container">
      <span class="eyebrow fade-in">Servicio a domicilio</span>
      <h1 class="hero__headline fade-in fade-in-delay-1">
        Pachamama HomeCare
      </h1>
      <p class="hero__sub fade-in fade-in-delay-2">
        Limpieza profesional de sofás, colchones y textiles del hogar.<br />
        Servicio especializado realizado directamente en tu domicilio con
        maquinaria profesional diseñada para limpieza profunda de textiles.<br />
        Disponible en Bogotá y Medellín.
      </p>
      <p class="mt-md fade-in fade-in-delay-3" style="max-width: 580px; color: var(--gray-700); font-size: 0.95rem;">
        Así como cuidamos los artículos de bebé en Pachamama Clean, ahora
        extendemos ese mismo estándar de limpieza a los textiles del hogar.
        Nuestro equipo técnico se desplaza a tu casa con equipos especializados
        que permiten realizar lavado profundo, desmanchado y procesos de
        higienización de muebles y textiles.
      </p>
      <div class="hero__badge-row fade-in fade-in-delay-3">
        <span class="badge">Bogotá</span>
        <span class="badge">Medellín</span>
      </div>
      <div class="mt-lg fade-in fade-in-delay-4">
        <a href="/contacto" class="btn btn-primary">Agendar servicio</a>
      </div>
    </div>
  </section>

  <!-- ─── EXPLICACIÓN DEL SERVICIO ─────────────────────────── -->
  <section class="section">
    <div class="container">
      <div class="split">
        <div class="split__text">
          <span class="eyebrow fade-in">Cómo funciona</span>
          <h2 class="fade-in fade-in-delay-1">
            Limpieza profunda directamente en tu hogar
          </h2>
          <div class="divider fade-in fade-in-delay-2"></div>
          <p class="mt-md fade-in fade-in-delay-2">
            A diferencia del servicio de Pachamama Clean, donde los artículos
            se procesan en nuestro taller, el servicio HomeCare se realiza
            directamente en tu casa. Nuestro equipo se desplaza con maquinaria
            especializada diseñada para limpieza profunda de textiles.
          </p>
          <p class="mt-md fade-in fade-in-delay-3">
            Los equipos utilizados permiten limpiar los textiles en profundidad
            sin necesidad de retirar los muebles del hogar.
          </p>
          <ul class="check-list mt-lg fade-in fade-in-delay-3">
            <li>Inyectar agua limpia en el tejido</li>
            <li>Remover la suciedad acumulada</li>
            <li>Extraer completamente el agua sucia</li>
          </ul>
        </div>
        <div class="fade-in fade-in-delay-2">
          <div
            class="img-placeholder"
            style="aspect-ratio: 4/5;"
            data-label="Máquina de extracción en sofá"
          ></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── PROCESO ───────────────────────────────────────────── -->
  <section class="section section--alt">
    <div class="container">
      <div class="text-center mb-md">
        <span class="eyebrow fade-in">Paso a paso</span>
        <h2 class="fade-in fade-in-delay-1">Proceso de limpieza HomeCare</h2>
        <div class="divider divider--center fade-in fade-in-delay-2"></div>
        <p
          class="lead mt-md fade-in fade-in-delay-2"
          style="max-width: 520px; margin-left: auto; margin-right: auto;"
        >
          Nuestro servicio incluye varias etapas para obtener un resultado
          profesional.
        </p>
      </div>
      <div class="steps mt-xl fade-in fade-in-delay-2">
        <div class="step">
          <div class="step__num">1</div>
          <div class="step__content">
            <h4>Cepillado y desmanchado</h4>
            <p>
              Se realiza un proceso inicial de cepillado para desprender
              suciedad superficial y tratar manchas visibles en el textil.
            </p>
          </div>
        </div>
        <div class="step">
          <div class="step__num">2</div>
          <div class="step__content">
            <h4>Aplicación de espuma</h4>
            <p>
              Se aplican productos especializados para limpieza de textiles
              que actúan sobre la suciedad acumulada dentro del tejido.
            </p>
          </div>
        </div>
        <div class="step">
          <div class="step__num">3</div>
          <div class="step__content">
            <h4>Lavado con maquinaria de inyección y extracción</h4>
            <p>
              Se utiliza maquinaria que inyecta agua limpia, remueve la
              suciedad profunda y extrae completamente el agua sucia.
            </p>
          </div>
        </div>
        <div class="step">
          <div class="step__num">4</div>
          <div class="step__content">
            <h4>Proceso de vaporización</h4>
            <p>
              Se aplica vaporización con máquina de vapor para ayudar en la
              higienización de las superficies textiles.
            </p>
          </div>
        </div>
        <div class="step">
          <div class="step__num">5</div>
          <div class="step__content">
            <h4>Ventilación y secado</h4>
            <p>
              Se utilizan ventiladores especializados para ayudar a acelerar
              el proceso de secado del textil.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── TÉCNICOS VERIFICADOS ──────────────────────────────── -->
  <section class="section">
    <div class="container">
      <div class="split split--reverse">
        <div class="split__text">
          <span class="eyebrow fade-in">Confianza</span>
          <h2 class="fade-in fade-in-delay-1">
            Técnicos Pachamama verificados
          </h2>
          <div class="divider fade-in fade-in-delay-2"></div>
          <p class="mt-md fade-in fade-in-delay-2">
            Sabemos que permitir el ingreso de personas a tu hogar es una
            decisión que requiere confianza. Por eso en Pachamama trabajamos
            con técnicos previamente seleccionados y verificados.
          </p>
          <p class="mt-md fade-in fade-in-delay-3">
            Nuestro proceso de contratación nos permite enviar a tu hogar
            personal confiable y capacitado, brindando tranquilidad a nuestros
            clientes durante la realización del servicio.
          </p>
          <ul class="check-list mt-lg fade-in fade-in-delay-3">
            <li>Verificación de antecedentes</li>
            <li>Perfil de seguridad</li>
            <li>Pruebas de confiabilidad</li>
            <li>Validación del personal antes de realizar servicios en domicilios</li>
          </ul>
        </div>
        <div class="fade-in fade-in-delay-1">
          <div
            class="img-placeholder"
            style="aspect-ratio: 4/5;"
            data-label="Técnico Pachamama uniformado"
          ></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── SERVICIOS DISPONIBLES ─────────────────────────────── -->
  <section class="section section--alt">
    <div class="container">
      <div class="text-center mb-md">
        <span class="eyebrow fade-in">Cobertura</span>
        <h2 class="fade-in fade-in-delay-1">Servicios HomeCare</h2>
        <div class="divider divider--center fade-in fade-in-delay-2"></div>
        <p
          class="lead mt-md fade-in fade-in-delay-2"
          style="max-width: 480px; margin-left: auto; margin-right: auto;"
        >
          Realizamos limpieza profesional de:
        </p>
      </div>
      <div class="grid-3 mt-xl">
        <div class="service-card fade-in fade-in-delay-1">
          <div class="img-placeholder" data-label="Sofás"></div>
          <div class="service-card__body">
            <div class="service-card__title">Sofás</div>
            <p class="service-card__text">2 puestos, 3 puestos y modulares.</p>
          </div>
        </div>
        <div class="service-card fade-in fade-in-delay-2">
          <div class="img-placeholder" data-label="Colchones"></div>
          <div class="service-card__body">
            <div class="service-card__title">Colchones</div>
            <p class="service-card__text">Sencillo, semidoble, doble y king.</p>
          </div>
        </div>
        <div class="service-card fade-in fade-in-delay-3">
          <div class="img-placeholder" data-label="Sillas de comedor"></div>
          <div class="service-card__body">
            <div class="service-card__title">Sillas de comedor</div>
            <p class="service-card__text">Tapizadas, por unidad.</p>
          </div>
        </div>
        <div class="service-card fade-in fade-in-delay-1">
          <div class="img-placeholder" data-label="Poltronas"></div>
          <div class="service-card__body">
            <div class="service-card__title">Poltronas</div>
            <p class="service-card__text">Sillones individuales tapizados.</p>
          </div>
        </div>
        <div class="service-card fade-in fade-in-delay-2">
          <div class="img-placeholder" data-label="Cabeceros"></div>
          <div class="service-card__body">
            <div class="service-card__title">Cabeceros y apoyacabezas</div>
            <p class="service-card__text">Tapizados de todo tipo.</p>
          </div>
        </div>
        <div class="service-card fade-in fade-in-delay-3">
          <div class="img-placeholder" data-label="Tapetes"></div>
          <div class="service-card__body">
            <div class="service-card__title">Tapetes</div>
            <p class="service-card__text">Lavado en taller. Ver detalle abajo.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── TAPETES ───────────────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <div class="split">
        <div class="split__text">
          <span class="eyebrow fade-in">Servicio especial</span>
          <h2 class="fade-in fade-in-delay-1">
            Lavado profesional de tapetes
          </h2>
          <div class="divider fade-in fade-in-delay-2"></div>
          <p class="mt-md fade-in fade-in-delay-2">
            Los tapetes requieren un proceso distinto al resto de los textiles
            del hogar. Debido a su densidad y capacidad de absorción, tardan más
            tiempo en secar después del lavado.
          </p>
          <p class="mt-md fade-in fade-in-delay-3">
            Por esta razón, el lavado de tapetes se realiza en nuestro taller,
            donde podemos controlar mejor el proceso de lavado profundo, secado
            adecuado y eliminación de malos olores.
          </p>
          <ul class="check-list mt-lg fade-in fade-in-delay-3">
            <li>Recolección del tapete en tu domicilio</li>
            <li>Lavado especializado en taller</li>
            <li>Secado completo para evitar humedad y olores</li>
            <li>Entrega en 5 días hábiles</li>
          </ul>
        </div>
        <div class="fade-in fade-in-delay-2">
          <div
            class="img-placeholder"
            style="aspect-ratio: 4/3;"
            data-label="Tapete en taller Pachamama"
          ></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── TARIFAS ───────────────────────────────────────────── -->
  <section class="section section--alt">
    <div class="container">
      <div class="text-center mb-md">
        <span class="eyebrow fade-in">Precios</span>
        <h2 class="fade-in fade-in-delay-1">Tarifas HomeCare</h2>
        <div class="divider divider--center fade-in fade-in-delay-2"></div>
      </div>
      <div class="grid-3 mt-xl">
        <div class="card fade-in fade-in-delay-1">
          <h4 class="font-serif mb-sm">Sillas y poltronas</h4>
          <ul class="price-list">
            <li><span>Silla de comedor</span><span>$20.000 / und</span></li>
            <li><span>Poltrona</span><span>$60.000</span></li>
            <li><span>Cabecero</span><span>$70.000</span></li>
          </ul>
        </div>
        <div class="card fade-in fade-in-delay-2">
          <h4 class="font-serif mb-sm">Sofás</h4>
          <ul class="price-list">
            <li><span>Sofá 2 puestos</span><span>$120.000</span></li>
            <li><span>Sofá 3 puestos</span><span>$150.000</span></li>
          </ul>
        </div>
        <div class="card fade-in fade-in-delay-3">
          <h4 class="font-serif mb-sm">Colchones</h4>
          <ul class="price-list">
            <li><span>Sencillo</span><span>$90.000</span></li>
            <li><span>Semidoble</span><span>$110.000</span></li>
            <li><span>Doble</span><span>$130.000</span></li>
            <li><span>King</span><span>$160.000</span></li>
          </ul>
        </div>
      </div>
      <div
        class="card mt-lg fade-in"
        style="max-width: 400px; margin-left: auto; margin-right: auto; text-align: center;"
      >
        <h4 class="font-serif mb-sm">Tapetes</h4>
        <p style="font-size: 1.2rem; font-weight: 600; color: var(--olive);">Desde $60.000</p>
        <p style="font-size: 0.82rem; color: var(--gray-500); margin-top: 0.3rem;">Precio según tamaño · Lavado en taller</p>
      </div>
      <div class="mt-xl fade-in">
        <ul class="check-list check-list--inline" style="max-width: 600px; margin: 0 auto;">
          <li>Servicio en domicilio</li>
          <li>Maquinaria profesional</li>
          <li>Bogotá y Medellín</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ─── CTA FINAL ─────────────────────────────────────────── -->
  <section class="section section--dark">
    <div class="container" style="text-align: center;">
      <h2 class="fade-in fade-in-delay-1" style="color: var(--white);">
        Agenda tu servicio HomeCare
      </h2>
      <p
        class="fade-in fade-in-delay-2"
        style="color: rgba(255,255,255,0.65); max-width: 480px; margin: 1rem auto 2rem;"
      >
        Nuestro equipo coordinará contigo el horario disponible.
      </p>
      <a href="/contacto" class="btn btn-outline-white fade-in fade-in-delay-3">
        Agendar servicio
      </a>
    </div>
  </section>
</Layout>

