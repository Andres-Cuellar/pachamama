			</div>
		</div>
	</section>

	<!-- ─── 5. PROCESO ───────────────────────────────────────── -->
	<section id="proceso-clean" class="section section--alt">
		<div class="container">
			<div class="text-center mb-md">
				<span class="eyebrow fade-in">Proceso técnico</span>
				<h2 class="fade-in fade-in-delay-1">Mucho más que un lavado</h2>
				<div class="divider divider--center fade-in fade-in-delay-2">
				</div>
				<p class="lead mt-md fade-in fade-in-delay-2">
					Cada artículo pasa por un proceso técnico de limpieza
					profunda, desinfección y mantenimiento especializado.
				</p>
			</div>
			<div class="steps mt-lg fade-in fade-in-delay-2">
				<div class="step">
					<div class="step__num">1</div>
					<div class="step__content">
						<h4>Inspección inicial</h4>
						<p>
							Evaluamos estado general, textiles, ruedas,
							rodamientos y mecanismos.
						</p>
					</div>
				</div>
				<div class="step">
					<div class="step__num">2</div>
					<div class="step__content">
						<h4>Desarme técnico</h4>
						<p>
							Se desmontan piezas para acceder a zonas difíciles.
						</p>
					</div>
				</div>
				<div class="step">
					<div class="step__num">3</div>
					<div class="step__content">
						<h4>Lavado profundo</h4>
						<p>
							Se limpian textiles, chasis, ruedas y piezas
							plásticas.
						</p>
					</div>
				</div>
				<div class="step">
					<div class="step__num">4</div>
					<div class="step__content">
						<h4>Mantenimiento de ruedas y rodamientos</h4>
						<p>
							Se retiran residuos como pelo, polvo y fibras
							acumuladas. Posteriormente se lubrican los
							rodamientos con aceite siliconado para mejorar su
							funcionamiento.
						</p>
					</div>
				</div>
				<div class="step">
					<div class="step__num">5</div>
					<div class="step__content">
						<h4>Revisión de mecanismos</h4>
						<p>
							Se revisan frenos, sistemas de plegado y uniones
							móviles.
						</p>
					</div>
				</div>
				<div class="step">
					<div class="step__num">6</div>
					<div class="step__content">
						<h4>Desinfección en cabina UV‑C</h4>
						<p>
							Los artículos pasan por una cabina de luz
							ultravioleta que ayuda a reducir microorganismos
							presentes en superficies textiles y plásticas.
						</p>
					</div>
				</div>
				<div class="step">
					<div class="step__num">7</div>
					<div class="step__content">
						<h4>Reensamble técnico y control final</h4>
						<p>
							El artículo se arma nuevamente y se realiza una
							revisión final de funcionamiento.
						</p>
					</div>
				</div>
			</div>
			<div class="grid-4 mt-xl">
				<div class="img-placeholder fade-in" data-label="Desarme"></div>
				<div
					class="img-placeholder fade-in fade-in-delay-1"
					data-label="Lavado"
				>
				</div>
				<div
					class="img-placeholder fade-in fade-in-delay-2"
					data-label="Ruedas y rodamientos"
				>
				</div>
				<div
					class="img-placeholder fade-in fade-in-delay-3"
					data-label="Cabina UV-C"
				>
				</div>
			</div>
		</div>
	</section>

	<!-- ─── 5b. SEÑALES ──────────────────────────────────────── -->
