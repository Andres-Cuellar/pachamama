---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <!-- ─── HERO ─────────────────────────────────────────────── -->
  <section class="hero hero--compact section--alt">
    <div class="container" style="max-width: 720px;">
      <span class="eyebrow fade-in">Puntos de atención</span>
      <h1 class="hero__headline fade-in fade-in-delay-1">
        Contacto y puntos de atención Pachamama
      </h1>
      <p class="hero__sub fade-in fade-in-delay-2">
        Agenda tu servicio de limpieza, mantenimiento o reparación de artículos
        de bebé, o conoce el coche Pachamama Click &amp; Go.
      </p>
      <p class="mt-md fade-in fade-in-delay-3" style="color: var(--gray-700);">
        Trabajamos principalmente con servicio a domicilio, pero también
        contamos con puntos de recepción aliados en Bogotá y Medellín donde
        puedes dejar o recoger tus artículos.
      </p>
      <div class="mt-xl fade-in fade-in-delay-4">
        <a
          href="https://wa.me/573108696543"
          class="whatsapp-btn"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg class="whatsapp-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"></path>
          </svg>
          Escribir por WhatsApp
        </a>
      </div>
    </div>
  </section>


  <!-- ─── CÓMO FUNCIONA ────────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <div class="split">
        <div class="split__text">
          <span class="eyebrow fade-in">El proceso</span>
          <h2 class="fade-in fade-in-delay-1">Cómo funciona Pachamama</h2>
          <div class="divider fade-in fade-in-delay-2"></div>
          <p class="mt-md fade-in fade-in-delay-2">
            Nuestro servicio está diseñado para que no tengas que desplazarte
            con los artículos de tu bebé.
          </p>
          <div class="steps mt-lg fade-in fade-in-delay-3">
            <div class="step">
              <div class="step__num">1</div>
              <div class="step__content">
                <h4>Escríbenos por WhatsApp</h4>
                <p>Cuéntanos qué artículo tienes y qué necesitas.</p>
              </div>
            </div>
            <div class="step">
              <div class="step__num">2</div>
              <div class="step__content">
                <h4>Programamos la recolección</h4>
                <p>
                  Coordinamos la recolección a domicilio o te indicamos el punto
                  de recepción más cercano.
                </p>
              </div>
            </div>
            <div class="step">
              <div class="step__num">3</div>
              <div class="step__content">
                <h4>Procesamos en taller</h4>
                <p>
                  El artículo se procesa en nuestro taller especializado con
                  estándares técnicos Pachamama.
                </p>
              </div>
            </div>
            <div class="step">
              <div class="step__num">4</div>
              <div class="step__content">
                <h4>Te lo devolvemos listo</h4>
                <p>
                  Limpio, desinfectado y funcionando correctamente. Directamente
                  a tu domicilio.
                </p>
              </div>
            </div>
          </div>
          <div class="note-box mt-lg fade-in fade-in-delay-4">
            <p>
              Muchos clientes prefieren la recolección a domicilio, pero también
              puedes utilizar nuestros puntos de recepción aliados.
            </p>
          </div>
        </div>
        <div class="fade-in fade-in-delay-1">
          <div
            class="img-placeholder"
            style="aspect-ratio: 4/5;"
            data-label="Técnico Pachamama — proceso de servicio"
          ></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── BOGOTÁ ───────────────────────────────────────────── -->
  <section class="section section--alt">
    <div class="container">
      <div class="text-center mb-md" style="max-width: 640px; margin-left: auto; margin-right: auto;">
        <span class="eyebrow fade-in">Bogotá</span>
        <h2 class="fade-in fade-in-delay-1">Puntos de atención en Bogotá</h2>
        <div class="divider divider--center fade-in fade-in-delay-2"></div>
        <p class="mt-md fade-in fade-in-delay-2">
          Si prefieres, puedes llevar tu coche o artículo directamente a
          nuestros puntos de recepción aliados <strong>Lavatex</strong> en el
          norte de Bogotá.
        </p>
        <p class="mt-sm fade-in fade-in-delay-3" style="font-size: 0.88rem; color: var(--gray-500);">
          Estos puntos funcionan únicamente como centros de recepción y entrega.
          El procesamiento se realiza en el taller especializado de Pachamama.
        </p>
      </div>

      <div class="grid-2 mt-xl" style="max-width: 860px; margin-left: auto; margin-right: auto;">
        <!-- Chicó -->
        <div class="card fade-in fade-in-delay-1">
          <span class="eyebrow" style="font-size: 0.7rem;">Punto de recepción</span>
          <h3 class="mt-sm">Chicó</h3>
          <div class="contact-point__address">
            <p>Barrio Chicó</p>
            <p>Calle 106 # 14B - 50</p>
          </div>
          <div class="contact-point__hours">
            <p><strong>Lunes a viernes</strong> 9:00 AM – 6:00 PM</p>
            <p><strong>Sábados</strong> 9:00 AM – 2:00 PM</p>
          </div>
          <div class="mt-lg">
            <a
              href="https://wa.me/573108696543"
              class="whatsapp-btn"
              target="_blank"
              rel="noopener noreferrer"
              style="font-size: 0.82rem; padding: 0.7rem 1.25rem;"
            >
              <svg class="whatsapp-icon" style="width:16px;height:16px;" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
